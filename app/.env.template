# =============================================================================
# .env.template - Environment variable template (no secrets)
# =============================================================================
# Summary: Copy to app/.env and fill in values. For Cloud Run, use Secret Manager
# and --set-secrets/--set-env-vars instead. Agent reads GOOGLE_API_KEY, AGENT_MODEL.
# =============================================================================

# --- Step 1: Choose Live API platform ---
# FALSE = Gemini Live API (aistudio.google.com); TRUE = Vertex AI (GCP)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Step 2a: Gemini Live API credentials (when USE_VERTEXAI=FALSE) ---
# Get key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# --- Step 2b: Vertex AI (when USE_VERTEXAI=TRUE) ---
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Step 3: Model selection (optional) ---
# Native audio: gemini-2.5-flash-native-audio-preview-12-2025 (voice I/O)
# Vertex: gemini-live-2.5-flash-native-audio
DEMO_AGENT_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
